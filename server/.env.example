SUPABASE_DB_URL=
# Optional fallback alias:
# DATABASE_URL=
JWT_SECRET=
# Required for Node server chat/WhatsApp routes. If you use Supabase Edge Functions only,
# set ANTHROPIC_API_KEY in Supabase secrets instead.
ANTHROPIC_API_KEY=
# Optional: only needed for legacy Node /api/files upload route.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v22.0
# Optional but recommended for validating webhook authenticity
WHATSAPP_APP_SECRET=
CLIENT_ORIGIN=http://localhost:3000
PORT=3001
